{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1xCB-JadfhSWvmFZIDJgLrYbGmO3mIdgW","timestamp":1772393732849},{"file_id":"1eY1Z4Jzo-DmCZJEWPMkFc-9-zV_qFb97","timestamp":1772393662942}],"toc_visible":true,"authorship_tag":"ABX9TyPfjuG4fi6UrXBqtdZXn8zI"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"BEFdTvEG26Ay"},"outputs":[],"source":["# Environment Setup\n","!sudo apt-get update -qq\n","!sudo apt-get install -y openbabel autodock-vina -qq\n","!pip install biopython pandas requests numpy"]},{"cell_type":"code","source":["from Bio import Entrez, SeqIO, pairwise2\n","from Bio.pairwise2 import format_alignment\n","\n","# 1. Setup Entrez\n","Entrez.email = \"240102020@atlas.edu.tr\" # Replace with your email address\n","\n","def find_fungal_islands(h_id, f_id):\n","    \"\"\"Finds continuous identical sequence islands between two proteins.\"\"\"\n","    h_seq = SeqIO.read(Entrez.efetch(db=\"protein\", id=h_id, rettype=\"fasta\"), \"fasta\").seq\n","    f_seq = SeqIO.read(Entrez.efetch(db=\"protein\", id=f_id, rettype=\"fasta\"), \"fasta\").seq\n","\n","    matches = \"\".join([h_seq[i] if h_seq[i] == f_seq[i] else \"-\" for i in range(min(len(h_seq), len(f_seq)))])\n","    islands = [s for s in matches.split('-') if len(s) > 5]\n","\n","    print(f\"Detected {len(islands)} ancient islands of identity.\")\n","    if islands:\n","        print(f\"Longest Fungal Ghost Island: {max(islands, key=len)}\")\n","    else:\n","        print(\"No Fungal Ghost Islands found.\")\n","    return islands\n","\n","def locate_ancient_engine(h_id, f_id):\n","    \"\"\"Performs local alignment to find the top high-affinity conserved region.\"\"\"\n","    h_seq = SeqIO.read(Entrez.efetch(db=\"protein\", id=h_id, rettype=\"fasta\"), \"fasta\").seq\n","    f_seq = SeqIO.read(Entrez.efetch(db=\"protein\", id=f_id, rettype=\"fasta\"), \"fasta\").seq\n","\n","    alignments = pairwise2.align.localxx(h_seq, f_seq)\n","    best = alignments[0]\n","    score = best[2]\n","    identity = (score / min(len(h_seq), len(f_seq))) * 100\n","\n","    print(f\"--- ATAVISTIC REPORT ---\")\n","    print(f\"Raw Match Score: {score}\")\n","    print(f\"Ancient Identity: {identity:.2f}%\")\n","    print(f\"\\nTop High-Affinity Region (The Ghost Engine):\")\n","    print(format_alignment(*best))\n","\n","# Run the analysis for SEPT9 (Human) vs Cdc3 (Yeast)\n","find_fungal_islands(\"Q9UHD8\", \"P32457\")\n","locate_ancient_engine(\"Q9UHD8\", \"P32457\")"],"metadata":{"id":"vLqHUvi_3MZ_"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import os\n","import subprocess\n","\n","def prepare_docking_environment():\n","    \"\"\"Generates the GTP ligand from a SMILES string to bypass download issues.\"\"\"\n","    gtp_smiles = \"Nc1nc2n(cnc2c(=O)[nH]1)[C@@H]3O[C@H](COP(=O)(O)OP(=O)(O)OP(=O)(O)O)[C@@H](O)[C@H]3O\"\n","    with open(\"gtp.smi\", \"w\") as f:\n","        f.write(gtp_smiles)\n","\n","    print(\"Generating GTP.pdbqt...\")\n","    os.system(\"obabel gtp.smi -O gtp.pdbqt --gen3d -h -p 7.4\")\n","\n","def run_atavistic_docking():\n","    targets = {\n","        \"6UQS\": {\"url\": \"https://files.rcsb.org/download/6UQS.pdb\", \"center\": {'x': 5.278, 'y': 11.683, 'z': 18.968}},\n","        \"2QAG\": {\"url\": \"https://files.rcsb.org/download/2QAG.pdb\", \"center\": {'x': 92.409, 'y': 76.922, 'z': 5.563}}\n","    }\n","\n","    results = []\n","\n","    for name, data in targets.items():\n","        print(f\"\\nProcessing Target: {name}...\")\n","        os.system(f\"wget -q {data['url']} -O {name}.pdb\")\n","        os.system(f\"obabel {name}.pdb -O {name}.pdbqt -xr -ph --gen3d\")\n","\n","        center = data['center']\n","        cmd = (f\"vina --receptor {name}.pdbqt --ligand gtp.pdbqt \"\n","               f\"--center_x {center['x']} --center_y {center['y']} --center_z {center['z']} \"\n","               f\"--size_x 20 --size_y 20 --size_z 20 --exhaustiveness 8\")\n","\n","        proc = subprocess.run(cmd, shell=True, capture_output=True, text=True)\n","\n","        score = 0.0\n","        for line in proc.stdout.split('\\n'):\n","            if line.strip().startswith('1'):\n","                try:\n","                    score = float(line.split()[1])\n","                    print(f\"🏆 Best Affinity Score: {score} kcal/mol\")\n","                except ValueError:\n","                    pass\n","                break\n","\n","        results.append(score)\n","\n","    print(\"\\n\" + \"=\"*30)\n","    print(f\"🧪 HUMAN (6UQS): {results[0]} kcal/mol\")\n","    print(f\"🍄 YEAST (2QAG): {results[1]} kcal/mol\")\n","    print(f\"🧬 ATAVISTIC DIFFERENCE: {abs(results[0] - results[1]):.3f} kcal/mol\")\n","    print(\"=\"*30)\n","\n","prepare_docking_environment()\n","run_atavistic_docking()"],"metadata":{"id":"q3wOAeVe3PSg"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from Bio.PDB import PDBParser\n","import numpy as np\n","\n","def calculate_grid_center(pdb_filename, target_chain, pocket_residues):\n","    \"\"\"\n","    Calculates the exact geometric center (x, y, z) of a specific binding pocket.\n","    This provides reproducible coordinates for AutoDock Vina grid boxes.\n","    \"\"\"\n","    parser = PDBParser(QUIET=True)\n","    structure = parser.get_structure(\"Protein\", pdb_filename)\n","\n","    coords = []\n","\n","    # Iterate through the structure to find the specific active site residues\n","    for model in structure:\n","        for chain in model:\n","            if chain.id == target_chain:\n","                for residue in chain:\n","                    # Check if the residue ID matches our target pocket list\n","                    if residue.id[1] in pocket_residues:\n","                        for atom in residue:\n","                            coords.append(atom.get_coord())\n","\n","    if not coords:\n","        print(f\"❌ Error: Could not find residues {pocket_residues} in chain {target_chain}.\")\n","        return None\n","\n","    # Calculate the centroid (average of all x, y, z coordinates)\n","    coords_array = np.array(coords)\n","    center = np.mean(coords_array, axis=0)\n","\n","    print(f\"✅ Grid Center Calculated for {pdb_filename}:\")\n","    print(f\"   --center_x {center[0]:.3f} --center_y {center[1]:.3f} --center_z {center[2]:.3f}\")\n","\n","    return {'x': center[0], 'y': center[1], 'z': center[2]}\n","\n","# Example Usage: Defining the P-loop (GTP binding site)\n","# (Replace the residue numbers with the exact ones from your notebook)\n","print(\"📐 CALCULATING DOCKING COORDINATES...\")\n","human_center = calculate_grid_center(\"6UQS.pdb\", target_chain=\"A\", pocket_residues=[30, 31, 32, 33, 34, 35, 36, 37])\n","yeast_center = calculate_grid_center(\"2QAG.pdb\", target_chain=\"A\", pocket_residues=[25, 26, 27, 28, 29, 30, 31, 32])"],"metadata":{"id":"OuyOkLpL30Nb"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import requests\n","import pandas as pd\n","import io\n","\n","def get_all_partners(gene_name, species_id, limit=100):\n","    \"\"\"Fetches the top interaction partners for a given gene from STRING.\"\"\"\n","    url = \"https://string-db.org/api/tsv/network\"\n","    params = {\n","        \"identifiers\": gene_name,\n","        \"species\": species_id,\n","        \"limit\": limit,\n","        \"required_score\": 400,\n","        \"caller_identity\": \"Atavistic_Project\"\n","    }\n","\n","    response = requests.get(url, params=params)\n","    if response.status_code == 200 and len(response.text) > 0:\n","        col_names = [\"stringId_A\", \"stringId_B\", \"preferredName_A\", \"preferredName_B\", \"score\", \"n\", \"f\", \"p\", \"as\", \"es\", \"d\", \"t\"]\n","        try:\n","            return pd.read_csv(io.StringIO(response.text), sep=\"\\t\", header=None, names=col_names)\n","        except pd.errors.EmptyDataError:\n","            return pd.DataFrame()\n","    return pd.DataFrame()\n","\n","def check_ortholog_existence(human_gene):\n","    \"\"\"Checks if a Yeast ortholog exists for a given Human gene.\"\"\"\n","    url = \"https://string-db.org/api/tsv/homology\"\n","    params = {\n","        \"identifiers\": human_gene,\n","        \"species_a\": 9606,  # Human\n","        \"species_b\": 4932,  # Yeast\n","        \"caller_identity\": \"Atavistic_Project\"\n","    }\n","\n","    response = requests.get(url, params=params)\n","    if response.status_code == 200 and len(response.text) > 0:\n","        col_names = [\"stringId_A\", \"stringId_B\", \"preferredName_A\", \"preferredName_B\", \"bitscore\"]\n","        try:\n","            df = pd.read_csv(io.StringIO(response.text), sep=\"\\t\", header=None, names=col_names)\n","            return df.iloc[0]['preferredName_B']\n","        except Exception:\n","            return None\n","    return None\n","\n","def analyze_engine_parts():\n","    \"\"\"Determines if the auxiliary proteins are ancient or modern.\"\"\"\n","    turbos = [\n","        {\"name\": \"MPRIP\", \"role\": \"Brakes (Myosin Phosphatase)\"},\n","        {\"name\": \"RTKN\",  \"role\": \"Scaffold (Rhotekin)\"},\n","        {\"name\": \"FLNA\",  \"role\": \"Chassis (Filamin A)\"},\n","        {\"name\": \"SEPT7\", \"role\": \"Transmission (Septin 7)\"}\n","    ]\n","\n","    print(\"🏎️  ANALYZING THE ENGINE PARTS (Old vs. New)...\")\n","    print(f\"{'PART':<10} | {'ROLE':<25} | {'STATUS'}\")\n","    print(\"-\" * 60)\n","\n","    for part in turbos:\n","        yeast_cousin = check_ortholog_existence(part['name'])\n","        if yeast_cousin:\n","            print(f\"{part['name']:<10} | {part['role']:<25} | ✅ ANCIENT (Found as '{yeast_cousin}')\")\n","        else:\n","            print(f\"{part['name']:<10} | {part['role']:<25} | 🆕 MODERN (No Yeast match found)\")\n","\n","analyze_engine_parts()"],"metadata":{"id":"4VsSx23v3S_9"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import requests\n","import pandas as pd\n","import io\n","\n","def get_partners(gene_name, species_id, limit=50):\n","    \"\"\"Fetches the top interaction partners for a specific gene from STRING.\"\"\"\n","    url = \"https://string-db.org/api/tsv/network\"\n","    params = {\n","        \"identifiers\": gene_name,\n","        \"species\": species_id,\n","        \"limit\": limit,\n","        \"caller_identity\": \"Atavistic_Project\"\n","    }\n","\n","    response = requests.get(url, params=params)\n","    if response.status_code == 200 and len(response.text) > 0:\n","        try:\n","            col_names = [\"stringId_A\", \"stringId_B\", \"preferredName_A\", \"preferredName_B\", \"score\", \"n\", \"f\", \"p\", \"as\", \"es\", \"d\", \"t\"]\n","            df = pd.read_csv(io.StringIO(response.text), sep=\"\\t\", header=None, names=col_names)\n","            # Compile a set of all partner names\n","            partners = set(df['preferredName_B'].unique()) | set(df['preferredName_A'].unique())\n","            return partners\n","        except pd.errors.EmptyDataError:\n","            return set()\n","    return set()\n","\n","def hunt_for_bridges():\n","    \"\"\"Finds indirect protein connections between SEPT9 and key cancer pathways.\"\"\"\n","    pathways = [\n","        {\"name\": \"Motility (Movement)\", \"target\": \"RHOA\"},\n","        {\"name\": \"Direction (Polarity)\", \"target\": \"CDC42\"},\n","        {\"name\": \"Adhesion (Sticking)\",  \"target\": \"PXN\"}\n","    ]\n","\n","    print(\"🕵️‍♂️ INITIATING 'BRIDGE HUNT' FOR HIDDEN CONNECTIONS...\")\n","    sept9_partners = get_partners(\"SEPT9\", 9606)\n","    print(f\"✅ SEPT9 has {len(sept9_partners)} primary partners.\\n\")\n","\n","    for p in pathways:\n","        target = p['target']\n","        print(f\"🔎 Investigating Path: SEPT9 ➡️ [ ??? ] ➡️ {target}...\")\n","\n","        target_partners = get_partners(target, 9606)\n","\n","        # Find the overlap (The Bridge)\n","        bridges = sept9_partners.intersection(target_partners)\n","\n","        # Remove the proteins themselves to isolate the intermediates\n","        bridges.discard(\"SEPT9\")\n","        bridges.discard(target)\n","\n","        if bridges:\n","            print(f\"   🚀 BRIDGE FOUND! The connection is INDIRECT via:\")\n","            for bridge in bridges:\n","                # Filter out API string artifacts\n","                if not bridge.startswith(\"9606\") and bridge not in [\"preferredName_B\", \"ncbiTaxonId\"]:\n","                    print(f\"      🔗 SEPT9 -> {bridge} -> {target}\")\n","        else:\n","            print(f\"   ❌ No common bridge found in top 50.\")\n","        print(\"-\" * 50)\n","\n","def check_sept7_hypothesis():\n","    \"\"\"Checks if SEPT7 specifically acts as a bridge for these targets.\"\"\"\n","    pathways = [\"RHOA\", \"CDC42\", \"PXN\"]\n","    print(\"\\n🧪 HYPOTHESIS CHECK: Is SEPT7 the key bridge?\")\n","    sept7_partners = get_partners(\"SEPT7\", 9606)\n","\n","    for target in pathways:\n","        if target in sept7_partners:\n","            print(f\"   🔥 YES! SEPT7 binds directly to {target}.\")\n","            print(f\"   (Evidence: SEPT9 binds SEPT7, and SEPT7 binds {target} -> The chain is complete.)\")\n","        else:\n","            print(f\"   ⚠️ SEPT7 does not bind {target} directly in the top 50 partners.\")\n","\n","hunt_for_bridges()\n","check_sept7_hypothesis()"],"metadata":{"id":"V5IZ2Har3WPz"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"MxAYFE5Q3Z-X"},"execution_count":null,"outputs":[]}]}